#!/usr/bin/env python3
"""retro-banner — render a machine's big ASCII boot banner in 24-bit color.

The art is DATA, not code (Cognitive Honing: push logic down, keep the
renderer generic). Each machine is one plain-text file:

    banners/<machine>.txt            (this repo — the shipped art)
    ~/.config/retro-terminals/banners/<machine>[.txt|.ans]   (your overrides)

A user file wins over the shipped one, so tweak by copying:

    cp banners/hal.txt ~/.config/retro-terminals/banners/hal.txt
    $EDITOR ~/.config/retro-terminals/banners/hal.txt
    tools/retro-banner hal           # preview the change instantly

File format — an optional header of `#:` directives, then the art verbatim:

    #: bg 0A0000                 background band color
    #: base FF6B6B               default color for unmatched glyphs
    #: frame 804040              color for box-drawing frame glyphs
    #: paint FFD24A ●            paint these glyphs this color (first match wins)
    #: line 4 E02020             paint entire art line 4 (1-based) — for stripes
    (first line NOT starting with "#:" begins the art)

Painting is glyph-based, so if you redraw the shape the colors follow the
characters automatically. `#: line` exists for the one thing glyph rules
can't do: rainbow stripes where the same `█` needs a different color per row.
A file with NO header prints verbatim (riding the terminal's own palette) —
that's also how hand-colored .ans files behave.

    tools/retro-banner hal            # render HAL in color
    tools/retro-banner --list
    tools/retro-banner hal --no-color # shape only, to check alignment
"""
import os
import sys

HERE = os.path.dirname(os.path.abspath(__file__))
REPO_BANNERS = os.path.join(HERE, os.pardir, "banners")
USER_BANNERS = os.environ.get(
    "RETRO_BANNER_DIR", os.path.expanduser("~/.config/retro-terminals/banners")
)

# Old / long names -> canonical banner keys (the retro-prompts.zsh keys).
ALIASES = {
    "weyland-yutani": "weyland", "hal9000": "hal", "voight-kampff": "vk",
    "nostromo": "mother", "commodore-64": "c64", "fallout-pip-boy": "pipboy",
}

# Box-drawing glyphs that default to the frame color when no paint rule hits.
FRAME = set("╭╮╰╯│─┌┐└┘├┤┬┴┼═║╔╗╚╝▔▁")

RESET = "\x1b[0m"


def fg(hexstr):
    r, g, b = (int(hexstr[i:i + 2], 16) for i in (0, 2, 4))
    return f"\x1b[38;2;{r};{g};{b}m"


def bg(hexstr):
    r, g, b = (int(hexstr[i:i + 2], 16) for i in (0, 2, 4))
    return f"\x1b[48;2;{r};{g};{b}m"


def find_banner(name):
    """User override wins; then the repo's shipped art. Returns a path or None."""
    key = ALIASES.get(name.lower(), name.lower())
    for d in (USER_BANNERS, REPO_BANNERS):
        for cand in (name.lower(), key):
            for ext in ("", ".txt", ".ans"):
                path = os.path.join(d, cand + ext)
                if os.path.isfile(path):
                    return path
    return None


def parse(path):
    """Split a banner file into (spec, art_lines). spec is None when the file
    has no `#:` header — the caller prints it verbatim."""
    with open(path, encoding="utf-8") as f:
        raw = f.read().splitlines()
    spec = {"bg": None, "base": None, "frame": None, "rules": [], "lines": {}}
    seen_header = False
    i = 0
    for i, ln in enumerate(raw):
        if not ln.startswith("#:"):
            break
        seen_header = True
        parts = ln[2:].strip().split(None, 2)
        if not parts:
            continue
        kind = parts[0]
        if kind in ("bg", "base", "frame") and len(parts) >= 2:
            spec[kind] = parts[1]
        elif kind == "paint" and len(parts) >= 3:
            spec["rules"].append((set(parts[2].replace(" ", "")), parts[1]))
        elif kind == "line" and len(parts) >= 3:
            spec["lines"][int(parts[1])] = parts[2]
    else:
        i += 1  # header-only file: no art lines
    if not seen_header:
        return None, raw
    art = raw[i:]
    # trim leading/trailing blank lines so files can breathe around the header
    while art and not art[0].strip():
        art.pop(0)
    while art and not art[-1].strip():
        art.pop()
    return spec, art


def paint(line, lineno, spec, color):
    if not color:
        return line
    row = spec["lines"].get(lineno)
    out = []
    for ch in line:
        if ch == " ":
            out.append(ch)
            continue
        if row:
            c = row
        elif any(ch in chars for chars, _ in spec["rules"]):
            c = next(hx for chars, hx in spec["rules"] if ch in chars)
        elif ch in FRAME and spec["frame"]:
            c = spec["frame"]
        else:
            c = spec["base"]
        out.append((fg(c) if c else "") + ch)
    return "".join(out)


def render(name, color=True):
    path = find_banner(name)
    if not path:
        sys.exit(f"unknown machine '{name}'. try: retro-banner --list")
    spec, art = parse(path)
    if spec is None:  # headerless file (e.g. hand-colored .ans): verbatim
        print("\n" + "\n".join(art).rstrip("\n") + "\n")
        return
    width = max((len(l) for l in art), default=0) + 3
    band = bg(spec["bg"]) if (color and spec["bg"]) else ""
    print()
    if band:
        print(band + " " * (width + 1) + RESET)
    for n, l in enumerate(art, 1):
        body = paint(l, n, spec, color) + (RESET + band if band else "")
        pad = " " * (width - len(l))
        print((band + " " if band else " ") + body + pad + (RESET if band else ""))
    if band:
        print(band + " " * (width + 1) + RESET)
    print()


def list_banners():
    shipped = sorted(
        f[:-4] for f in os.listdir(REPO_BANNERS)
        if f.endswith(".txt") and os.path.isfile(os.path.join(REPO_BANNERS, f))
    ) if os.path.isdir(REPO_BANNERS) else []
    print("shipped banners:", ", ".join(shipped))
    print(f"your overrides win: {USER_BANNERS}/<machine>[.txt|.ans]")


def main():
    args = sys.argv[1:]
    color = "--no-color" not in args
    names = [a for a in args if not a.startswith("-")]
    if not names or "--list" in args:
        list_banners()
        if not names:
            return
    render(names[0], color=color)


if __name__ == "__main__":
    main()
