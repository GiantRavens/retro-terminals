def user_art(*names):
    for n in names:
        if not n:
            continue
        for cand in (n, n + ".txt", n + ".ans"):
            path = os.path.join(BANNER_DIR, cand)
            if os.path.isfile(path):
                return path
    return None


def render(name, color=True):
    key = ALIASES.get(name.lower(), name.lower())
    override = user_art(name.lower(), key)
    if override:
        with open(override) as f:
            print("\n" + f.read().rstrip("\n") + "\n")
        return
    spec = MACHINES.get(key)
    if not spec:
        sys.exit(f"unknown machine '{name}'. try: {', '.join(MACHINES)}")
    lines = spec["art"].strip("\n").splitlines()
    width = max((len(l) for l in lines), default=0) + 3
    out = []
    for l in lines:
        body = paint(l, spec, color) + (RESET if color else "")
        pad = " " * (width - len(l))
        if color:
            out.append(bg(spec["bg"]) + " " + body + pad + RESET)
        else:
            out.append(" " + l + pad)
    top = (bg(spec["bg"]) + " " * (width + 1) + RESET) if color else ""
    print()
    if color:
        print(top)
    print("\n".join(out))
    if color:
        print(top)
    print()


def main():
    args = [a for a in sys.argv[1:]]
    color = "--no-color" not in args
    args = [a for a in args if not a.startswith("-")]
    if not args or "--list" in sys.argv[1:]:
        print("built-in banners:", ", ".join(MACHINES))
        print(f"paste your own (wins over built-in): {BANNER_DIR}/<machine>[.txt]")
        if not args:
            return
    render(args[0], color=color)


if __name__ == "__main__":
    main()
