def paint(line, spec, color):
    out = []
    for ch in line:
        if not color or ch == " ":
            out.append(ch)
            continue
        c = None
        if ch in FRAME:
            c = spec["frame"]
        else:
            for chars, hx in spec["rules"]:
                if ch in chars:
                    c = hx
                    break
            if c is None:
                c = spec["base"]
        out.append(fg(c) + ch)
    return "".join(out)


