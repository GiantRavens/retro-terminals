# ---------------------------------------------------------------------------
# 24-bit color helpers. Hexes mirror the machine palettes in build_profiles.py
# ---------------------------------------------------------------------------
def fg(hexstr):
    r, g, b = (int(hexstr[i:i+2], 16) for i in (0, 2, 4))
    return f"\x1b[38;2;{r};{g};{b}m"

def bg(hexstr):
    r, g, b = (int(hexstr[i:i+2], 16) for i in (0, 2, 4))
    return f"\x1b[48;2;{r};{g};{b}m"

RESET = "\x1b[0m"
BOLD = "\x1b[1m"

